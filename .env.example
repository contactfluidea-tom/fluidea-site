# === Fluidea — Variables d'environnement (exemple) ===
# Copiez ce fichier en `.env.local` puis renseignez vos valeurs :
#   cp .env.example .env.local
# Les variables préfixées par NEXT_PUBLIC_ sont exposées au navigateur.
# Les mêmes clés doivent être ajoutées dans Vercel → Settings → Environment Variables.

# --- Requises ---

# URL publique du site — sert au canonical, à l'Open Graph et au sitemap.
# Production : le vrai domaine. En local, mettre http://localhost:3000.
NEXT_PUBLIC_SITE_URL=https://fluidea.pro

# Calendrier Calendly — événement « appel découverte » (widget Réservation).
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/fluidea-appel/appel-decouverte

# Scène Spline de la page FAQ (/faq) — ambiance 3D en arrière-plan.
NEXT_PUBLIC_FAQ_SPLINE_URL=https://prod.spline.design/XCkzCgkJK37ndXZz/scene.splinecode

# Formulaire de contact — clé API Resend (backend par défaut, route /api/contact).
# Laisser vide en local : le message est alors journalisé, pas envoyé.
# En production : renseigner la vraie clé Resend (commence par "re_").
RESEND_API_KEY=

# --- Optionnelles ---

# Destinataire et expéditeur des e-mails de contact (sinon valeurs par défaut du code).
# L'expéditeur doit utiliser un domaine vérifié dans Resend (ex. contact@fluidea.pro).
# CONTACT_TO=contact.fluidea@gmail.com
# RESEND_FROM=Fluidea <contact@fluidea.pro>

# Scène Spline du Hero (si utilisée). Vide = pas de scène Hero distante.
# NEXT_PUBLIC_SPLINE_SCENE_URL=

# Alternative SANS backend (export statique) : clé Web3Forms. Si définie, le
# formulaire poste directement vers Web3Forms au lieu de /api/contact.
# NEXT_PUBLIC_WEB3FORMS_KEY=
